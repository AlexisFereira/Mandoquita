DATABASE_URL="postgresql://user:password@localhost:5432/mandoquita_catalog"
NEXT_PUBLIC_ASSET_BASE_URL=""
PRODUCT_WRITE_API_KEY="replace-with-at-least-32-random-characters"

PRODUCT_ADMIN_ORIGIN="http://localhost:3000"
PRODUCT_ADMIN_TRUST_PROXY="false"
PRODUCT_ADMIN_TRUSTED_PROXY_HOPS="1"

PRODUCT_ADMIN_CODE_HASH="scrypt$16384$8$1$<salt>$<derived-key>"
PRODUCT_ADMIN_SESSION_SECRET="replace-with-independent-random-value-of-at-least-32-bytes"
PRODUCT_ADMIN_EDGE_SECRET="replace-with-independent-edge-secret-of-at-least-32-bytes"

AWS_REGION="us-east-1"
AWS_S3_BUCKET="mandoquita-product-images"
AWS_S3_PUBLIC_BASE_URL="https://cdn.example.com"
AWS_S3_IMAGE_PREFIX="images/products"
AWS_S3_IMAGE_MAX_BYTES="5242880"
AWS_S3_KMS_KEY_ID="arn:aws:kms:region:account-id:key/key-id"
AWS_ACCESS_KEY_ID="replace-with-deployment-secret"
AWS_SECRET_ACCESS_KEY="replace-with-deployment-secret"
AWS_SESSION_TOKEN=""
