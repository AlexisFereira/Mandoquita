{
  "name": "mandoquita-catalog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run --config vitest.config.ts",
    "test:integration:postgres": "tsx scripts/validate-product-lifecycle.ts",
    "test:integration:taxonomy": "tsx scripts/validate-taxonomy.ts",
    "test:integration:product-content": "tsx scripts/validate-product-content-variants.ts",
    "test:integration:product-seed": "tsx scripts/validate-product-seed.ts",
    "test:integration:search": "tsx scripts/validate-public-search.ts",
    "test:integration:product-admin": "tsx scripts/validate-product-admin.ts",
    "test:integration:catalog-media": "tsx scripts/validate-catalog-media-admin.ts",
    "test:integration:admin-catalog-v2": "tsx scripts/validate-admin-catalog-v2.ts",
    "test:browser:homepage": "node scripts/validate-homepage-merchandising-browser.cjs",
    "test:browser:product-detail": "node scripts/validate-product-detail-contact-browser.cjs",
    "catalog-media:cleanup": "tsx scripts/cleanup-catalog-media.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init_catalog",
    "prisma:seed": "prisma db seed",
