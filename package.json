{
  "name": "mandoquita-catalog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run --config vitest.config.ts",
    "test:integration:postgres": "tsx scripts/validate-product-lifecycle.ts",
    "test:integration:taxonomy": "tsx scripts/validate-taxonomy.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init_catalog",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@prisma/client": "^6.11.1",
    "autoprefixer": "^10.5.2",
    "next": "^14.2.5",
    "postcss": "^8.5.16",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.3.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.6.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "jsdom": "^22.1.0",
    "prisma": "^6.11.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
