generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaxonomyStatus {
  PROPOSED
  APPROVED
  ACTIVE
  SUPERSEDED
}

enum GenderApplicability {
  MUJER
  HOMBRE
  UNISEX
  NO_APLICA
}

enum VariantAttributeName {
  TALLA
  COLOR
  MATERIAL
  CAPACIDAD
  PRESENTACION
}

enum VariantAttributeValueType {
  TEXT
  NUMBER
  BOOLEAN
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

model TaxonomyVersion {
  id         String         @id
  version    String         @unique
  locale     String
  status     TaxonomyStatus
  categories Category[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model Category {
  id                 String              @id
  slug               String              @unique
  name               String
  description        String?
  imagePath          String?
  imageAltText       String?
  imageObjectKey     String?
  imageContentType   String?
  imageWidth         Int?
  imageHeight        Int?
  imageSize          Int?
  imageChecksum      String?
  sortOrder          Int
  active             Boolean             @default(true)
  visible            Boolean             @default(true)
  versionId          String
  version            TaxonomyVersion     @relation(fields: [versionId], references: [id])
  subcategories      Subcategory[]
  slugAliases        CategorySlugAlias[]
  retiredAt          DateTime?
  retiredByAccountId String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([versionId, sortOrder])
  @@index([versionId, active, visible, sortOrder])
}

model CategorySlugAlias {
  slug       String   @id
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdAt  DateTime @default(now())

  @@index([categoryId])
}

model Subcategory {
  id           String        @id
  slug         String        @unique
  name         String
  sourceOrder  Int
  active       Boolean       @default(true)
  categoryId   String
  category     Category      @relation(fields: [categoryId], references: [id])
  productTypes ProductType[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([categoryId, sourceOrder])
  @@index([categoryId, active, sourceOrder])
}

model ProductType {
  name          String      @id
  sourceOrder   Int
  active        Boolean     @default(true)
  subcategoryId String
  subcategory   Subcategory @relation(fields: [subcategoryId], references: [id])
  products      Product[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([subcategoryId, sourceOrder])
  @@index([subcategoryId, active, sourceOrder])
}

model Product {
  id                    Int                  @id @default(autoincrement())
  slug                  String               @unique
  name                  String
  description           String?
  shortDescription      String?
  brand                 String?
  collection            String?
  genderApplicability   GenderApplicability?
  seoTitle              String?
  seoDescription        String?
  price                 Decimal              @db.Decimal(10, 2)
  currency              String               @default("USD")
  active                Boolean              @default(true)
  editorialApproved     Boolean              @default(true)
  published             Boolean              @default(true)
  commerciallyAvailable Boolean              @default(true)
  featured              Boolean              @default(false)
  featuredOrder         Int?
  productTypeId         String?
  productType           ProductType?         @relation(fields: [productTypeId], references: [name])
  variants              ProductVariant[]
  images                ProductImage[]
  tags                  ProductTag[]
  slugAliases           ProductSlugAlias[]
  retiredAt             DateTime?
  retiredByAccountId    String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([productTypeId])
  @@index([active])
  @@index([published, productTypeId])
  @@index([productTypeId, published, commerciallyAvailable(sort: Desc), updatedAt(sort: Desc), id], map: "Product_related_by_type_idx")
  @@index([active, featured, featuredOrder])
  @@index([slug])
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin, map: "Product_search_name_trgm_idx")
  @@index([shortDescription(ops: raw("gin_trgm_ops"))], type: Gin, map: "Product_search_short_description_trgm_idx")
  @@index([description(ops: raw("gin_trgm_ops"))], type: Gin, map: "Product_search_description_trgm_idx")
  @@index([brand(ops: raw("gin_trgm_ops"))], type: Gin, map: "Product_search_brand_trgm_idx")
  @@index([collection(ops: raw("gin_trgm_ops"))], type: Gin, map: "Product_search_collection_trgm_idx")
}

model ProductSlugAlias {
  slug      String   @id
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())

  @@index([productId])
}

model ProductVariant {
  id         String             @id @default(cuid())
  productId  Int
  product    Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku        String             @unique
  reference  String?
  barcode    String?
  active     Boolean            @default(true)
  isBase     Boolean            @default(false)
  imageId    String?
  image      ProductImage?      @relation(fields: [imageId, productId], references: [id, productId])
  attributes VariantAttribute[]
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([productId, active])
  @@index([imageId, productId])
}

model VariantAttribute {
  id           String                    @id @default(cuid())
  variantId    String
  variant      ProductVariant            @relation(fields: [variantId], references: [id], onDelete: Cascade)
  name         VariantAttributeName
  valueType    VariantAttributeValueType
  textValue    String?
  numberValue  Decimal?                  @db.Decimal(18, 4)
  booleanValue Boolean?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  @@unique([variantId, name])
  @@index([name])
}

model ProductImage {
  id          String           @id @default(cuid())
  productId   Int
  product     Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  url         String
  objectKey   String?
  altText     String
  contentType String?
  width       Int?
  height      Int?
  size        Int?
  checksum    String?
  position    Int
  isPrimary   Boolean          @default(false)
  variants    ProductVariant[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([id, productId])
  @@unique([productId, position])
  @@index([productId, isPrimary, position])
}

model ProductTag {
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  value     String

  @@id([productId, value])
  @@index([value])
  @@index([value(ops: raw("gin_trgm_ops"))], type: Gin, map: "ProductTag_search_value_trgm_idx")
}

model ProductAdminSession {
  id                    String                    @id @default(cuid())
  tokenHash             String                    @unique
  csrfHash              String
  credentialFingerprint String
  adminAccountId        String?
  adminAccount          AdminAccount?             @relation(fields: [adminAccountId], references: [id], onDelete: Restrict)
  credentialVersion     Int?
  createdAt             DateTime                  @default(now())
  lastActivityAt        DateTime                  @default(now())
  idleExpiresAt         DateTime
  absoluteExpiresAt     DateTime
  revokedAt             DateTime?
  updatedAt             DateTime                  @updatedAt
  mediaUploads          CatalogMediaUpload[]
  mediaIdempotency      CatalogMediaIdempotency[]
  mediaRateLimit        CatalogMediaRateLimit?

  @@index([idleExpiresAt, absoluteExpiresAt, revokedAt], map: "ProductAdminSession_expiry_idx")
  @@index([createdAt], map: "ProductAdminSession_cleanup_idx")
  @@index([adminAccountId, revokedAt], map: "ProductAdminSession_account_idx")
}

model AdminAccount {
  id                 String                @id @default(cuid())
  username           String
  normalizedUsername String                @unique
  passwordHash       String
  role               AdminRole
  enabled            Boolean               @default(true)
  mustChangePassword Boolean               @default(true)
  credentialVersion  Int                   @default(1)
  passwordChangedAt  DateTime?
  lastLoginAt        DateTime?
  sessions           ProductAdminSession[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([role, enabled])
}

model ProductAdminThrottle {
  scope           String
  keyHash         String
  windowStartedAt DateTime
  failureCount    Int       @default(0)
  lockedUntil     DateTime?
  updatedAt       DateTime  @updatedAt

  @@id([scope, keyHash])
  @@index([lockedUntil], map: "ProductAdminThrottle_lock_idx")
  @@index([updatedAt], map: "ProductAdminThrottle_cleanup_idx")
}

model ProductAdminAuditEvent {
  id                BigInt    @id @default(autoincrement())
  occurredAt        DateTime  @default(now())
  requestId         String
  event             String
  outcome           String
  reason            String?
  sessionIdHash     String?
  productId         Int?
  categoryId        String?
  mediaId           String?
  mediaUploadHash   String?
  detectedType      String?
  encodedSize       Int?
  checksumPrefix    String?
  expectedUpdatedAt DateTime?
  currentUpdatedAt  DateTime?
  changedFields     Json?
  actorAccountId    String?
  targetAccountId   String?

  @@index([occurredAt], map: "ProductAdminAuditEvent_retention_idx")
  @@index([productId, occurredAt], map: "ProductAdminAuditEvent_product_idx")
  @@index([categoryId, occurredAt], map: "ProductAdminAuditEvent_category_idx")
  @@index([actorAccountId, occurredAt], map: "ProductAdminAuditEvent_actor_idx")
  @@index([targetAccountId, occurredAt], map: "ProductAdminAuditEvent_target_account_idx")
}

model CatalogMediaUpload {
  id                 String              @id @default(cuid())
  sessionId          String
  session            ProductAdminSession @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  kind               String
  idempotencyKeyHash String
  requestHash        String
  objectKey          String              @unique
  deliveryUrl        String
  contentType        String
  size               Int
  width              Int
  height             Int
  checksumSha256     String
  originalNameHash   String
  status             String              @default("READY")
  expiresAt          DateTime
  consumedAt         DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([sessionId, idempotencyKeyHash], map: "CatalogMediaUpload_session_idempotency_key")
  @@index([status, expiresAt], map: "CatalogMediaUpload_expiry_idx")
}

model CatalogMediaIdempotency {
  id          String              @id @default(cuid())
  sessionId   String
  session     ProductAdminSession @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  keyHash     String
  requestHash String
  operation   String
  response    Json
  expiresAt   DateTime
  createdAt   DateTime            @default(now())

  @@unique([sessionId, keyHash], map: "CatalogMediaIdempotency_session_key")
  @@index([expiresAt], map: "CatalogMediaIdempotency_expiry_idx")
}

model CatalogMediaObjectCleanup {
  id              String    @id @default(cuid())
  objectKey       String    @unique
  deliveryUrl     String
  reason          String
  status          String    @default("PENDING")
  restoreMetadata Json?
  deleteAfter     DateTime
  attempts        Int       @default(0)
  lastErrorCode   String?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status, deleteAfter], map: "CatalogMediaObjectCleanup_due_idx")
}

model CatalogMediaRateLimit {
  sessionId       String              @id
  session         ProductAdminSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  windowStartedAt DateTime
  uploadCount     Int                 @default(0)
  mutationCount   Int                 @default(0)
  updatedAt       DateTime            @updatedAt
}
