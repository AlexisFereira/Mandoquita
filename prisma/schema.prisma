generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaxonomyStatus {
  PROPOSED
  APPROVED
  ACTIVE
  SUPERSEDED
}

enum GenderApplicability {
  MUJER
  HOMBRE
  UNISEX
  NO_APLICA
}

enum VariantAttributeName {
  TALLA
  COLOR
  MATERIAL
  CAPACIDAD
  PRESENTACION
}

enum VariantAttributeValueType {
  TEXT
  NUMBER
  BOOLEAN
}

model TaxonomyVersion {
  id         String         @id
  version    String         @unique
  locale     String
  status     TaxonomyStatus
  categories Category[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model Category {
  id            String          @id
  slug          String          @unique
  name          String
  description   String?
  imagePath     String?
  imageAltText  String?
  sortOrder     Int
  active        Boolean         @default(true)
  visible       Boolean         @default(true)
  versionId     String
  version       TaxonomyVersion @relation(fields: [versionId], references: [id])
  subcategories Subcategory[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([versionId, sortOrder])
  @@index([versionId, active, visible, sortOrder])
}

model Subcategory {
  id           String        @id
  slug         String        @unique
  name         String
  sourceOrder  Int
  active       Boolean       @default(true)
  categoryId   String
  category     Category      @relation(fields: [categoryId], references: [id])
  productTypes ProductType[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([categoryId, sourceOrder])
  @@index([categoryId, active, sourceOrder])
}

model ProductType {
  name          String      @id
  sourceOrder   Int
  active        Boolean     @default(true)
  subcategoryId String
  subcategory   Subcategory @relation(fields: [subcategoryId], references: [id])
  products      Product[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([subcategoryId, sourceOrder])
  @@index([subcategoryId, active, sourceOrder])
}

model Product {
  id                    Int                  @id @default(autoincrement())
  slug                  String               @unique
  name                  String
  description           String?
  shortDescription      String?
  brand                 String?
  collection            String?
  genderApplicability   GenderApplicability?
  seoTitle              String?
  seoDescription        String?
  price                 Decimal              @db.Decimal(10, 2)
  currency              String               @default("USD")
  active                Boolean              @default(true)
  editorialApproved     Boolean              @default(true)
  published             Boolean              @default(true)
  commerciallyAvailable Boolean              @default(true)
  featured              Boolean              @default(false)
  featuredOrder         Int?
  productTypeId         String?
  productType           ProductType?         @relation(fields: [productTypeId], references: [name])
  variants              ProductVariant[]
  images                ProductImage[]
  tags                  ProductTag[]
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([productTypeId])
  @@index([active])
  @@index([published, productTypeId])
  @@index([productTypeId, published, commerciallyAvailable(sort: Desc), updatedAt(sort: Desc), id], map: "Product_related_by_type_idx")
  @@index([active, featured, featuredOrder])
  @@index([slug])
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin, map: "Product_search_name_trgm_idx")
  @@index([shortDescription(ops: raw("gin_trgm_ops"))], type: Gin, map: "Product_search_short_description_trgm_idx")
  @@index([description(ops: raw("gin_trgm_ops"))], type: Gin, map: "Product_search_description_trgm_idx")
  @@index([brand(ops: raw("gin_trgm_ops"))], type: Gin, map: "Product_search_brand_trgm_idx")
  @@index([collection(ops: raw("gin_trgm_ops"))], type: Gin, map: "Product_search_collection_trgm_idx")
}

model ProductVariant {
  id         String             @id @default(cuid())
  productId  Int
  product    Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku        String             @unique
  reference  String?
  barcode    String?
  active     Boolean            @default(true)
  isBase     Boolean            @default(false)
  imageId    String?
  image      ProductImage?      @relation(fields: [imageId, productId], references: [id, productId])
  attributes VariantAttribute[]
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([productId, active])
  @@index([imageId, productId])
}

model VariantAttribute {
  id           String                    @id @default(cuid())
  variantId    String
  variant      ProductVariant            @relation(fields: [variantId], references: [id], onDelete: Cascade)
  name         VariantAttributeName
  valueType    VariantAttributeValueType
  textValue    String?
  numberValue  Decimal?                  @db.Decimal(18, 4)
  booleanValue Boolean?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  @@unique([variantId, name])
  @@index([name])
}

model ProductImage {
  id        String           @id @default(cuid())
  productId Int
  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  altText   String
  position  Int
  isPrimary Boolean          @default(false)
  variants  ProductVariant[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([id, productId])
  @@unique([productId, position])
  @@index([productId, isPrimary, position])
}

model ProductTag {
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  value     String

  @@id([productId, value])
  @@index([value])
  @@index([value(ops: raw("gin_trgm_ops"))], type: Gin, map: "ProductTag_search_value_trgm_idx")
}

model ProductAdminSession {
  id                    String    @id @default(cuid())
  tokenHash             String    @unique
  csrfHash              String
  credentialFingerprint String
  createdAt             DateTime  @default(now())
  lastActivityAt        DateTime  @default(now())
  idleExpiresAt         DateTime
  absoluteExpiresAt     DateTime
  revokedAt             DateTime?
  updatedAt             DateTime  @updatedAt

  @@index([idleExpiresAt, absoluteExpiresAt, revokedAt], map: "ProductAdminSession_expiry_idx")
  @@index([createdAt], map: "ProductAdminSession_cleanup_idx")
}

model ProductAdminThrottle {
  scope           String
  keyHash         String
  windowStartedAt DateTime
  failureCount    Int       @default(0)
  lockedUntil     DateTime?
  updatedAt       DateTime  @updatedAt

  @@id([scope, keyHash])
  @@index([lockedUntil], map: "ProductAdminThrottle_lock_idx")
  @@index([updatedAt], map: "ProductAdminThrottle_cleanup_idx")
}

model ProductAdminAuditEvent {
  id                BigInt   @id @default(autoincrement())
  occurredAt        DateTime @default(now())
  requestId         String
  event             String
  outcome           String
  reason            String?
  sessionIdHash     String?
  productId         Int?
  expectedUpdatedAt DateTime?
  currentUpdatedAt  DateTime?
  changedFields     Json?

  @@index([occurredAt], map: "ProductAdminAuditEvent_retention_idx")
  @@index([productId, occurredAt], map: "ProductAdminAuditEvent_product_idx")
}
